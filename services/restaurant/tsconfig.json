{
  "compilerOptions": {
    // File Layout
     "rootDir": "./src",
     "outDir": "./dist",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2020",
    
    // For nodejs:
     "lib": ["es2020"],
     "types": ["node"],
    
    // Other Outputs
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,

    
    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true

  }
}
